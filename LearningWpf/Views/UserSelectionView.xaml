<UserControl x:Class="LearningWpf.Views.UserSelectionView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:converters="clr-namespace:LearningWpf.Converters">
    <!-- 1. SCHRITT: Namensraum importieren -->

    <UserControl.Resources>
        <!-- 2. SCHRITT: Den Converter als Ressource für dieses Control registrieren -->
        <converters:NullToBoolConverter x:Key="NullToBoolConverter"/>

        <Style x:Key="LabelStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Foreground" Value="#666666"/>
            <Setter Property="Margin" Value="0,0,0,4"/>
        </Style>

        <Style x:Key="ComboBoxGroupStyle" TargetType="StackPanel">
            <Setter Property="Margin" Value="0,0,0,16"/>
        </Style>
    </UserControl.Resources>

    <StackPanel Margin="24">

        <TextBlock Text="{Binding XXX}"
               FontSize="14"
               FontWeight="Bold"
               Foreground="Crimson"
               Margin="0,0,0,8"/>

        
        <!-- Titel -->
        <TextBlock Text="BenutzerauswahlXXX"
                   FontSize="20"
                   FontWeight="SemiBold"
                   Margin="0,0,0,24"/>

        <!-- Benutzer -->
        <StackPanel Style="{StaticResource ComboBoxGroupStyle}">
            <TextBlock Text="Benutzer" Style="{StaticResource LabelStyle}"/>
            <ComboBox ItemsSource="{Binding Users}"
                      SelectedItem="{Binding SelectedUser}"
                      DisplayMemberPath="Name"
                      Width="300"
                      HorizontalAlignment="Left"/>
        </StackPanel>

        <!-- JobGroup — nur aktiv wenn User gewählt -->
        <StackPanel Style="{StaticResource ComboBoxGroupStyle}">
            <TextBlock Text="Job-Gruppe" Style="{StaticResource LabelStyle}"/>
            <ComboBox ItemsSource="{Binding AvailableJobGroups}"
                      SelectedItem="{Binding SelectedJobGroup}"
                      DisplayMemberPath="Name"
                      Width="300"
                      HorizontalAlignment="Left"
                      IsEnabled="{Binding SelectedUser, Converter={StaticResource NullToBoolConverter}, Mode=OneWay}"/>
            <!-- Hinweis: Mode=OneWay für sauberes Binding ergänzt -->
            <TextBlock Text="{Binding SelectedJobGroup.Description}"
                       FontSize="11"
                       Foreground="#888888"
                       Margin="0,4,0,0"/>
        </StackPanel>
    </StackPanel>

</UserControl>
